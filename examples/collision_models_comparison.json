{
  "metadata": {
    "description": "Collision model comparison: EHSS vs HSS vs Langevin",
    "purpose": "Demonstrate different collision physics implementations",
    "scientific_application": "Collision physics validation, method comparison"
  },
  
  "simulation": {
    "timestep_ns": 0.1,
    "max_time_ns": 2000.0,
    "integrator": "rk4",
    "random_seed": 42,
    "output_interval": 200,
    "enable_gpu": false
  },
  
  "instrument": {
    "type": "IMS",
    "geometry": {
      "radius_m": 0.01,
      "length_m": 0.15
    },
    "voltages": {
      "dc_axial_V": 300.0
    }
  },
  
  "ions": {
    "species": [
      {
        "name": "H+",
        "mass_amu": 1.00783,
        "charge": 1,
        "initial_count": 1000,
        "reduced_mobility_cm2_Vs": 9.8,
        "collision_cross_section_A2": 10.0
      },
      {
        "name": "H2O+",
        "mass_amu": 18.0106,
        "charge": 1,
        "initial_count": 1000,
        "reduced_mobility_cm2_Vs": 2.8,
        "collision_cross_section_A2": 30.0
      },
      {
        "name": "N2+",
        "mass_amu": 28.014,
        "charge": 1,
        "initial_count": 500,
        "reduced_mobility_cm2_Vs": 2.2,
        "collision_cross_section_A2": 45.0
      }
    ],
    "initial_distribution": {
      "type": "gaussian",
      "position": {
        "center": [0.0, 0.0, 0.0],
        "sigma": [0.002, 0.002, 0.002]
      },
      "velocity": {
        "temperature_K": 300.0,
        "directed_velocity": [2000.0, 0.0, 0.0]
      }
    }
  },
  
  "fields": {},
  
  "environment": {
    "gas_species": "He",
    "temperature_K": 300.0,
    "pressure_Pa": 250.0,
    "gas_velocity_m_s": [0.0, 0.0, 0.0]
  },
  
  "collisions": {
    "enabled": true,
    "model": "EHSS"
  },
  
  "output": {
    "trajectory_file": "collision_models_comparison.h5",
    "save_trajectories": true,
    "save_final_positions": true,
    "compression": true
  }
}
