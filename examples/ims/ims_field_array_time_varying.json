{
  "_comment": "Example: Superposition of DC and RF-modulated field arrays. DC term gives drift field (500 V/cm), RF term adds oscillating focusing (±100V @ 1MHz).",
  "simulation": {
    "total_time_s": 1e-5,
    "dt_s": 1e-9,
    "write_interval": 10,
    "integrator": "RK4",
    "enable_gpu": false,
    "enable_openmp": true,
    "rng_seed": 42
  },
  "physics": {
    "collision_model": "None",
    "enable_space_charge": false
  },
  "output": {
    "folder": "results/field_array_rf_modulation",
    "trajectory_file": "trajectories.h5",
    "print_progress": false
  },
  "ions": {
    "species": [
      {
        "id": "H3O+",
        "count": 100,
        "position": {
          "type": "gaussian",
          "center": [0.0, 0.0, 0.001],
          "std": [0.001, 0.001, 0.0005]
        },
        "velocity": {
          "type": "thermal",
          "temperature_K": 300.0
        }
      }
    ]
  },
  "domains": [
    {
      "name": "rf_modulated_region",
      "instrument": "IMS",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.05,
        "radius_m": 0.01
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 101325.0,
        "gas_species": "N2",
        "gas_velocity_m_s": [0.0, 0.0, 0.0]
      },
      "fields": {
        "DC": {
          "axial_V": 500.0
        },
        "RF": {
          "voltage_V": 100.0,
          "frequency_Hz": 1e6,
          "phase_rad": 0.0
        },
        "field_array_terms": [
          {
            "_comment": "Field array represents 200 V/cm (20kV/m) field",
            "file": "examples/field_arrays/ims_drift_200Vcm.h5",
            "scale_type": "DC_Axial",
            "_scaling": "Array scaled by DC.axial_V / 200 = 500/200 = 2.5x → 500 V/cm effective"
          },
          {
            "_comment": "Same field array but RF-modulated for ion focusing",
            "file": "examples/field_arrays/ims_drift_200Vcm.h5",
            "scale_type": "RF",
            "frequency_Hz": 1e6,
            "phase_rad": 0.0,
            "_scaling": "Array scaled by RF.voltage_V * cos(ωt+φ) / 200 = ±100/200 = ±0.5x oscillating"
          }
        ]
      }
    }
  ]
}
