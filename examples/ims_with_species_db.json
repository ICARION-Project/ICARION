{
  "title": "IMS Basic Validation with Species Database",
  "simulation": {
    "integrator": "rk4",
    "dt_s": 1e-9,
    "total_time_s": 1e-4,
    "write_interval": 100
  },
  "physics": {
    "collision_model": "hs",
    "enable_space_charge": false,
    "enable_reactions": false
  },
  "output": {
    "trajectory_file": "ims_validation_trajectory.h5"
  },
  "species_database": "../data/species_database_v1.json",
  "ion_cloud": "ion_clouds/default_cloud.json",
  "domains": [
    {
      "name": "drift_region",
      "instrument": "IMS",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.1,
        "radius_m": 0.02
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 101325.0,
        "gas": "N2"
      },
      "fields": {
        "DC": {
          "EN_Td": 10.0,
          "axial_V": 0.0
        }
      }
    }
  ]
}
