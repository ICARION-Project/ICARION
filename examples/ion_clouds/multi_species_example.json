{
  "title": "Multi-Species Ion Cloud Example",
  "description": "Demonstrates per-species position boundaries and velocity distributions",
  "comment": "Each species can have its own spatial region and velocity distribution",
  
  "species": [
    {
      "id": "H3O+",
      "count": 500,
      "comment": "H3O+ ions in gaussian cloud at origin",
      "position": {
        "type": "gaussian",
        "center": [0.0, 0.0, 0.0],
        "std": [0.001, 0.001, 0.001]
      },
      "velocity": {
        "type": "thermal",
        "temperature_K": 300
      }
    },
    {
      "id": "H5O2+",
      "count": 500,
      "comment": "H5O2+ ions in sphere at different location",
      "position": {
        "type": "uniform_sphere",
        "center": [0.005, 0.0, 0.0],
        "radius": 0.002
      },
      "velocity": {
        "type": "thermal",
        "temperature_K": 350
      }
    },
    {
      "id": "O2-",
      "count": 100,
      "comment": "O2- ions in cylinder with directed velocity",
      "position": {
        "type": "uniform_cylinder",
        "center": [0.0, 0.0, 0.01],
        "radius": 0.001,
        "length": 0.005
      },
      "velocity": {
        "type": "kinetic",
        "energy_eV": 0.1,
        "direction": [0, 0, 1],
        "spread_angle_deg": 10
      }
    }
  ]
}
