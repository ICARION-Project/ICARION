{
  "title": "Ion-Molecule Reactions Example",
  "simulation": {
    "integrator": "rk4",
    "dt_s": 1e-9,
    "total_time_s": 1e-3,
    "write_interval": 1000
  },
  "physics": {
    "collision_model": "hs",
    "enable_spacecharge": false,
    "enable_reactions": true
  },
  "output": {
    "trajectory_file": "reaction_demo_trajectory.h5"
  },
  "species_database": "../data/species_database_v1.json",
  "reaction_database": "../data/reactions_database_v1.json",
  "ion_cloud": "ion_clouds/default_cloud.json",
  "domains": [
    {
      "name": "reaction_cell",
      "instrument": "IMS",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.05,
        "radius_m": 0.01
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 101325.0,
        "gas": "N2"
      },
      "fields": {
        "DC": {
          "EN_Td": 0.0,
          "axial_V": 0.0
        }
      }
    }
  ]
}
