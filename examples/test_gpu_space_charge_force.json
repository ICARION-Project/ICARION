{
  "_comment": "GPU Space Charge Integration Test - Automatic dispatch",
  "simulation": {
    "total_time_s": 1e-7,
    "dt_s": 1e-10,
    "write_interval": 100,
    "integrator": "RK4",
    "enable_gpu": true,
    "gpu_threshold": 500,
    "enable_openmp": true,
    "rng_seed": 42
  },
  "physics": {
    "collision_model": "NoCollisions",
    "enable_space_charge": true
  },
  "output": {
    "folder": "results/test_gpu_space_charge_force",
    "trajectory_file": "gpu_sc_force.h5",
    "print_progress": true
  },
  "ions": {
    "species": [
      {
        "_comment": "2000 ions to trigger GPU space charge (N >= 1000)",
        "id": "H3O+",
        "count": 2000,
        "position": {
          "type": "gaussian",
          "center": [0.0, 0.0, 0.005],
          "std": [0.001, 0.001, 0.0005]
        },
        "velocity": {
          "type": "thermal",
          "temperature_K": 300.0
        }
      }
    ]
  },
  "domains": [
    {
      "name": "test_chamber",
      "instrument": "CUSTOM",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.02,
        "radius_m": 0.005
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 1e-6,
        "gas_species": "He",
        "gas_velocity_m_s": [0.0, 0.0, 0.0]
      },
      "fields": {
        "DC": {
          "EN_Td": 0.0,
          "axial_V": 0.0
        }
      }
    }
  ]
}
