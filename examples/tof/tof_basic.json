{
  "_comment": "Basic Time-of-Flight (TOF) mass spectrometer with orthogonal acceleration",
  "simulation": {
    "total_time_s": 1e-4,
    "dt_s": 1e-10,
    "write_interval": 100,
    "integrator": "RK4",
    "enable_gpu": false,
    "enable_openmp": true,
    "rng_seed": 42
  },
  "physics": {
    "collision_model": "NoCollisions",
    "enable_space_charge": false
  },
  "output": {
    "folder": "results/tof",
    "trajectory_file": "tof_trajectories.h5",
    "print_progress": true
  },
  "ions": {
    "species": [
      {
        "_comment": "Reserpine [M+H]+ at m/z 609",
        "id": "ReserpineH+",
        "count": 50,
        "position": {
          "type": "gaussian",
          "center": [0.0, 0.0, 0.001],
          "std": [0.0005, 0.0005, 0.0002]
        },
        "velocity": {
          "type": "thermal",
          "temperature_K": 300.0
        }
      },
      {
        "_comment": "Caffeine [M+H]+ at m/z 195",
        "id": "CaffeineH+",
        "count": 50,
        "position": {
          "type": "gaussian",
          "center": [0.0, 0.0, 0.001],
          "std": [0.0005, 0.0005, 0.0002]
        },
        "velocity": {
          "type": "thermal",
          "temperature_K": 300.0
        }
      }
    ]
  },
  "domains": [
    {
      "_comment": "Acceleration region: 2 kV over 2 cm = 100 kV/m",
      "name": "tof_acceleration",
      "instrument": "TOF",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 1.0,
        "radius_m": 0.05,
        "acc_length_m": 0.02
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 1e-6,
        "gas_species": "He"
      },
      "fields": {
        "DC": {
          "axial_V": 2000.0
        }
      },
      "boundary": {
        "type": "Absorption"
      }
    },
    {
      "_comment": "Detector at end of flight tube (z = 1.0 m)",
      "name": "tof_detector",
      "instrument": "NoFixedInstrument",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.999],
        "length_m": 0.001,
        "radius_m": 0.05
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 1e-6,
        "gas_species": "He"
      },
      "fields": {
        "DC": {
          "axial_V": 0.0
        }
      },
      "boundary": {
        "type": "Absorption"
      }
    }
  ]
}
