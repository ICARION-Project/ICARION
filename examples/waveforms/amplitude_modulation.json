{
  "title": "Amplitude Modulation Example",
  "description": "AC field with sinusoidal amplitude modulation",
  
  "simulation": {
    "total_time_s": 0.01,
    "dt_s": 1e-9,
    "integrator": "RK4",
    "write_interval": 1000
  },
  
  "physics": {
    "collision_model": "NoCollisions",
    "enable_reactions": false,
    "enable_space_charge": false
  },
  
  "output": {
    "folder": "./results/waveform_amplitude_modulation",
    "trajectory_file": "trajectories.h5",
    "print_progress": true
  },
  
  "domains": [
    {
      "name": "modulated_ac_region",
      "instrument": "NoFixedInstrument",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.05,
        "radius_m": 0.01
      },
      "env": {
        "pressure_Pa": 1e-3,
        "temperature_K": 300.0,
        "gas_species": "He"
      },
      "fields": {
        "AC": {
          "voltage_V": {
            "type": "sinusoidal",
            "offset": 250.0,
            "amplitude": 50.0,
            "frequency_Hz": 100.0,
            "phase_rad": 0.0
          },
          "frequency_Hz": 1000000.0
        }
      }
    }
  ]
}
