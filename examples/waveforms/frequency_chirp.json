{
  "title": "RF Frequency Chirp Example",
  "description": "RF quadrupole with linear frequency sweep (chirp) from 1MHz to 2MHz",
  
  "simulation": {
    "total_time_s": 0.01,
    "dt_s": 1e-9,
    "integrator": "RK4",
    "write_interval": 1000
  },
  
  "physics": {
    "collision_model": "NoCollisions",
    "enable_reactions": false,
    "enable_space_charge": false
  },
  
  "output": {
    "folder": "./results/waveform_outputs",
    "trajectory_file": "trajectories.h5",
    "print_progress": true
  },
  "ions": {
    "species": [
      {
        "id": "H3O+",
        "count": 100,
        "position": {
          "type": "gaussian",
          "center": [0.0, 0.0, 0.001],
          "std": [0.001, 0.001, 0.0005]
        },
        "velocity": {
          "type": "thermal",
          "temperature_K": 300.0
        }
      }
    ]
  },
  
  "domains": [
    {
      "name": "rf_quadrupole",
      "instrument": "Quadrupole",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.1,
        "radius_m": 0.005
      },
      "env": {
        "pressure_Pa": 1e-3,
        "temperature_K": 300.0,
        "gas_species": "He"
      },
      "fields": {
        "RF": {
          "voltage_V": 300.0,
          "frequency_Hz": {
            "type": "linear",
            "start": 1000000.0,
            "end": 2000000.0,
            "start_time_s": 0.0,
            "end_time_s": 0.01,
            "clamp": false
          }
        }
      }
    }
  ]
}
