{
  "title": "IMS with Linear Voltage Ramp (End-to-End Waveform Test)",
  "description": "Demonstrates waveform system: DC voltage ramps from 0V to 500V over 1ms",
  
  "simulation": {
    "total_time_s": 0.0005,
    "dt_s": 1e-8,
    "write_interval": 5000,
    "integrator": "RK4",
    "rng_seed": 42
  },
  
  "physics": {
    "collision_model": "HSS",
    "enable_reactions": false,
    "enable_space_charge": false
  },
  
  "output": {
    "folder": "./results/waveform_ims",
    "trajectory_file": "trajectories.h5",
    "print_progress": true
  },
  
  "ions": {
    "species": [
      {
        "id": "H3O+",
        "count": 50,
        "position": {
          "type": "gaussian",
          "center": [0.0, 0.0, 0.001],
          "std": [0.001, 0.001, 0.0003]
        },
        "velocity": {
          "type": "thermal",
          "temperature_K": 300.0
        }
      }
    ]
  },
  
  "domains": [
    {
      "name": "drift_region",
      "instrument": "IMS",
      "geometry": {
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.05,
        "radius_m": 0.01
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 200.0,
        "gas_species": "He"
      },
      "fields": {
        "waveforms": {
          "voltage_ramp": {
            "type": "linear",
            "start": 0.0,
            "end": 500.0,
            "start_time_s": 0.0,
            "end_time_s": 0.001,
            "clamp": true
          }
        },
        "DC": {
          "axial_V": "@voltage_ramp"
        }
      }
    }
  ]
}
