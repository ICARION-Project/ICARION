{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icarion.io/schemas/v1.1.0/output.schema.json",
  "title": "ICARION Output Configuration",
  "description": "Output file and logging configuration",
  "type": "object",
  
  "properties": {
    "folder": {
      "type": "string",
      "default": "./results",
      "description": "Output folder for results (relative or absolute path)"
    },
    
    "trajectory_file": {
      "type": "string",
      "default": "trajectories.h5",
      "description": "Trajectory output filename (HDF5 format)"
    },

    "trajectory_mode": {
      "type": "string",
      "enum": ["full", "minimal"],
      "default": "full",
      "description": "Trajectory output mode. full writes /trajectory time-series data; minimal skips trajectory snapshots and writes compact per-ion final-state output under /analysis/minimal_transport"
    },
    
    "print_progress": {
      "type": "boolean",
      "default": true,
      "description": "Enable progress printing to console"
    },

    "buffer_byte_cap": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Optional RAM cap for trajectory buffer in bytes (0 = unlimited)"
    },

    "deep_analysis": {
      "type": "object",
      "description": "Optional per-ion and per-event collision diagnostics written to /analysis/deep_collision",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["off", "summary", "sampled_events", "full_events"],
          "default": "off",
          "description": "Deep collision diagnostics mode. summary stores per-ion aggregates; sampled_events/full_events additionally store event rows"
        },
        "domain_filter_index": {
          "type": "integer",
          "minimum": -1,
          "default": -1,
          "description": "Restrict diagnostics to one domain index, or -1 for all domains"
        },
        "sample_every_n": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "For sampled_events mode, store every Nth collision event per ion"
        },
        "max_events_per_ion": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Optional cap on stored event rows per ion (0 = unlimited)"
        }
      },
      "additionalProperties": false
    },

    "deep_analysis_mode": {
      "type": "string",
      "enum": ["off", "summary", "sampled_events", "full_events"],
      "default": "off",
      "description": "Backward-compatible flat alias for deep_analysis.mode"
    },

    "deep_analysis_domain_filter_index": {
      "type": "integer",
      "minimum": -1,
      "default": -1,
      "description": "Backward-compatible flat alias for deep_analysis.domain_filter_index"
    },

    "deep_analysis_sample_every_n": {
      "type": "integer",
      "minimum": 1,
      "default": 10,
      "description": "Backward-compatible flat alias for deep_analysis.sample_every_n"
    },

    "deep_analysis_max_events_per_ion": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Backward-compatible flat alias for deep_analysis.max_events_per_ion"
    }
  },

  "additionalProperties": false
}
