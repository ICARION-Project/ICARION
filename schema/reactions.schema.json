{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://icarion.org/schemas/reactions/v1.0.json",
  "title": "ICARION Reaction Database Schema",
  "description": "Schema for ICARION reaction database (v1.0). Defines single reactant to single product reactions with concentration-dependent rate constants.",
  "type": "object",
  "required": ["reactions"],
  "additionalProperties": false,
  "properties": {
    "reactions": {
      "type": "array",
      "description": "Array of reaction definitions",
      "items": {
        "type": "object",
        "required": ["id", "reactant", "product", "rate_constant_m3s"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique reaction identifier",
            "pattern": "^[A-Za-z0-9_\\-]+$",
            "minLength": 1
          },
          "reactant": {
            "type": "string",
            "description": "Species ID of the reactant (must exist in species database)",
            "pattern": "^[A-Za-z0-9+\\-_]+$",
            "minLength": 1
          },
          "product": {
            "type": "string",
            "description": "Species ID of the product (must exist in species database)",
            "pattern": "^[A-Za-z0-9+\\-_]+$",
            "minLength": 1
          },
          "rate_constant_m3s": {
            "type": "number",
            "description": "Base rate constant in m³/s (pseudo-first-order)",
            "exclusiveMinimum": 0
          },
          "order": {
            "type": "array",
            "description": "Optional concentration-dependent order terms for effective rate calculation",
            "items": {
              "type": "object",
              "required": ["species", "exponent"],
              "additionalProperties": false,
              "properties": {
                "species": {
                  "type": "string",
                  "description": "Species ID for concentration dependence (must exist in species database)",
                  "pattern": "^[A-Za-z0-9+\\-_]+$",
                  "minLength": 1
                },
                "exponent": {
                  "type": "integer",
                  "description": "Exponent for concentration term (0, 1, or 2)",
                  "minimum": 0,
                  "maximum": 2
                },
                "concentration_m3": {
                  "type": "number",
                  "description": "Optional fixed concentration in m⁻³ (for pseudo-first-order conditions)",
                  "exclusiveMinimum": 0
                }
              }
            },
            "minItems": 0,
            "maxItems": 10
          },
          "description": {
            "type": "string",
            "description": "Optional human-readable description of the reaction",
            "minLength": 1
          },
          "reference": {
            "type": "string",
            "description": "Optional literature reference for rate constant",
            "minLength": 1
          },
          "temperature_K": {
            "type": "number",
            "description": "Temperature in Kelvin at which rate constant was measured",
            "exclusiveMinimum": 0
          }
        }
      },
      "minItems": 0
    }
  },
  "examples": [
    {
      "reactions": [
        {
          "id": "rxn_001_h3o_to_h5o2",
          "reactant": "H3O+",
          "product": "H5O2+",
          "rate_constant_m3s": 3.5e-15,
          "order": [
            {
              "species": "H2O",
              "exponent": 1,
              "concentration_m3": 2.5e25
            }
          ],
          "description": "Proton transfer from H3O+ to water cluster",
          "reference": "Smith et al., J. Chem. Phys. (2020)",
          "temperature_K": 300.0
        },
        {
          "id": "rxn_002_h5o2_dissociation",
          "reactant": "H5O2+",
          "product": "H3O+",
          "rate_constant_m3s": 1.2e-16,
          "order": [],
          "description": "Dissociation of water cluster",
          "temperature_K": 300.0
        }
      ]
    }
  ]
}
