{
  "metadata": {
    "description": "TOF validation configuration",
    "purpose": "General CPU/GPU trajectory consistency validation",
    "expected_runtime_seconds": 30,
    "scientific_application": "CPU/GPU numerical consistency (parity) validation"
  },
  "simulation": {
    "timestep_ns": 0.1,
    "max_time_ns": 50000,
    "integrator": "rk4",
    "random_seed": 42,
    "output_interval": 400,
    "enable_gpu": true
  },
  "instrument": {
    "type": "TOF",
    "geometry": {
      "length_m": 1.5,
      "acc_length_m": 0.02,
      "radius_m": 0.025
    },
    "voltages": {
      "dc_axial_V": 150.0
    }
  },
  "ions": {
    "species": [
      {
        "name": "TestIon+",
        "mass_amu": 100.0,
        "charge": 1,
        "initial_count": 10000,
        "reduced_mobility_cm2_Vs": 2.0,
        "collision_cross_section_A2": 120.0
      }
    ],
    "initial_distribution": {
      "type": "gaussian",
      "position": {
        "center": [
          0.0,
          0.0,
          0.0
        ],
        "sigma": [
          0.002,
          0.002,
          0.002
        ]
      },
      "velocity": {
        "temperature_K": 300.0,
        "directed_velocity": [
          0.0,
          0.0,
          0.0
        ]
      }
    }
  },
  "fields": {},
  "environment": {
    "gas_species": "N2",
    "temperature_K": 300.0,
    "pressure_Pa": 1e-8,
    "gas_velocity_m_s": [
      0.0,
      0.0,
      0.0
    ]
  },
  "collisions": {
    "enabled": true,
    "model": "HSS"
  },
  "output": {
    "trajectory_file": "cpu_gpu_parity_TOF.h5",
    "save_trajectories": true,
    "save_final_positions": true,
    "compression": true
  }
}