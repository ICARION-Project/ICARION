{
  "simulation": {
    "total_time_s": 1e-4,
    "dt_s": 1e-9,
    "write_interval": 10000,
    "integrator": "RK4",
    "enable_openmp": true,
    "enable_gpu": false,
    "rng_seed": 42
  },
  "output": {
    "folder": "results/thread_benchmark",
    "trajectory_file": "trajectories.h5",
    "print_progress": false
  },
  "physics": {
    "collision_model": "NoCollisions",
    "enable_space_charge": false
  },
  "ions": {
    "species": [
      {
        "id": "H3O+",
        "count": 10000,
        "position": {
          "type": "gaussian",
          "center": [0.0, 0.0, 0.05],
          "std": [0.005, 0.005, 0.01]
        },
        "velocity": {
          "type": "thermal",
          "temperature_K": 300.0,
          "drift_velocity_ms": [0.0, 0.0, 100.0]
        }
      }
    ]
  },
  "domains": [
    {
      "name": "drift_tube",
      "instrument": "IMS",
      "geometry": {
        "type": "Cylinder",
        "origin_m": [0.0, 0.0, 0.0],
        "length_m": 0.1,
        "radius_m": 0.05
      },
      "env": {
        "temperature_K": 300.0,
        "pressure_Pa": 1000.0,
        "gas_species": "N2"
      },
      "fields": {
        "dc": {
          "axial_V": 1000.0
        }
      }
    }
  ]
}
